import { useState, useRef } from 'react';
import { GoogleGenAI, Type } from "@google/genai";
import { 
  FileText, 
  Upload, 
  AlertTriangle, 
  ShieldAlert, 
  Scale, 
  CheckCircle2, 
  Info,
  Loader2,
  ChevronRight
} from 'lucide-react';
import { motion, AnimatePresence } from 'motion/react';
import Markdown from 'react-markdown';

// Types
interface RiskItem {
  label: string;
  desc: string;
  score: number;
  type: 'high' | 'mid' | 'low';
  clause: string;
}

interface AnalysisResult {
  summary: string;
  risks: RiskItem[];
  documentType: string;
}

export default function App() {
  const [file, setFile] = useState<File | null>(null);
  const [textInput, setTextInput] = useState('');
  const [isAnalyzing, setIsAnalyzing] = useState(false);
  const [result, setResult] = useState<AnalysisResult | null>(null);
  const [error, setError] = useState<string | null>(null);
  const fileInputRef = useRef<HTMLInputElement>(null);

  const handleFileUpload = (e: React.ChangeEvent<HTMLInputElement>) => {
    const selectedFile = e.target.files?.[0];
    if (selectedFile) {
      setFile(selectedFile);
      const reader = new FileReader();
      reader.onload = (event) => {
        setTextInput(event.target?.result as string);
      };
      reader.readAsText(selectedFile);
    }
  };

  const analyzeDocument = async () => {
    if (!textInput.trim()) return;

    setIsAnalyzing(true);
    setError(null);

    try {
      const ai = new GoogleGenAI({ apiKey: process.env.GEMINI_API_KEY });
      
      const response = await ai.models.generateContent({
        model: "gemini-3-flash-preview",
        contents: [
          {
            text: `Analyze the following legal document (contract, agreement, or terms). 
            
            Produce:
            1. A plain-language summary suitable for a general adult audience (18+). Translate legal jargon into simple concepts. Use Markdown for formatting.
            2. A risk surface map identifying clauses that are unusual, one-sided, or waive significant rights.
            3. Rank these risks by potential impact on the user (0-10 scale).
            
            Document content:
            ${textInput}
            `
          }
        ],
        config: {
          responseMimeType: "application/json",
          responseSchema: {
            type: Type.OBJECT,
            properties: {
              documentType: { type: Type.STRING, description: "Type of agreement (e.g. Employment, Loan, Rental)" },
              summary: { type: Type.STRING, description: "Plain-language summary in markdown" },
              risks: {
                type: Type.ARRAY,
                items: {
                  type: Type.OBJECT,
                  properties: {
                    label: { type: Type.STRING, description: "Short title of the risk" },
                    desc: { type: Type.STRING, description: "Plain explanation of why it is a risk" },
                    score: { type: Type.NUMBER, description: "Risk score from 0-10" },
                    type: { type: Type.STRING, enum: ["high", "mid", "low"], description: "Risk level" },
                    clause: { type: Type.STRING, description: "Reference to the original clause or section" }
                  },
                  required: ["label", "desc", "score", "type", "clause"]
                }
              }
            },
            required: ["documentType", "summary", "risks"]
          }
        }
      });

      const data = JSON.parse(response.text || '{}');
      setResult(data);
    } catch (err) {
      console.error(err);
      setError("Failed to analyze the document. Please ensure the content is valid legal text.");
    } finally {
      setIsAnalyzing(false);
    }
  };

  return (
    <div className="max-w-[1200px] mx-auto p-8 min-h-screen flex flex-col">
      {/* Header */}
      <header className="flex justify-between items-center mb-10">
        <div className="logo-area">
          <h1 className="text-2xl font-bold tracking-tight text-white uppercase italic">
            LEXICON <span className="text-text-secondary not-italic">ASSIST</span>
          </h1>
          <span className="text-[10px] text-text-secondary uppercase tracking-[3px] font-semibold">
            Human Augmentation System
          </span>
        </div>
        <div className="bg-glass border border-glass-border px-4 py-1.5 rounded-full text-xs font-medium text-text-secondary">
          Assistive Perception Module v1.0
        </div>
      </header>

      {/* Main Action Area */}
      {!result ? (
        <motion.div 
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          className="flex-grow flex flex-col items-center justify-center max-w-2xl mx-auto w-full"
        >
          <div className="glass-card w-full text-center space-y-6">
            <div className="w-16 h-16 bg-white/5 rounded-2xl flex items-center justify-center mx-auto border border-white/10">
              <Upload className="text-text-secondary" size={32} />
            </div>
            
            <div className="space-y-2">
              <h2 className="text-2xl font-semibold text-white">Upload Agreement</h2>
              <p className="text-text-secondary text-sm">
                Rental, employment, loan, or terms of service. We'll identify what you're waiving.
              </p>
            </div>

            <div 
              onClick={() => fileInputRef.current?.click()}
              className="border-2 border-dashed border-white/10 rounded-xl p-8 cursor-pointer hover:border-white/20 transition-colors group bg-white/[0.02]"
            >
              <input 
                type="file" 
                className="hidden" 
                ref={fileInputRef}
                onChange={handleFileUpload}
                accept=".txt,.md"
              />
              <p className="text-sm text-text-secondary group-hover:text-white transition-colors">
                {file ? file.name : "Drag & drop a text file, or click to browse"}
              </p>
              <div className="mt-4 text-[10px] text-zinc-600 uppercase tracking-widest">
                Currently supporting .txt and .md
              </div>
            </div>

            <div className="space-y-2">
              <p className="text-xs text-text-secondary uppercase tracking-widest font-bold">Or paste text directly</p>
              <textarea 
                value={textInput}
                onChange={(e) => setTextInput(e.target.value)}
                className="w-full h-32 bg-black/20 border border-white/10 rounded-xl p-4 text-sm text-text-primary focus:outline-none focus:border-white/30 resize-none"
                placeholder="Paste the legal clauses here..."
              />
            </div>

            {error && (
              <div className="text-risk-high text-xs bg-risk-high/10 p-3 rounded-lg border border-risk-high/20 flex items-center gap-2">
                <AlertTriangle size={14} />
                {error}
              </div>
            )}

            <button
              onClick={analyzeDocument}
              disabled={isAnalyzing || !textInput.trim()}
              className="w-full py-3 bg-white text-black font-bold rounded-xl hover:bg-zinc-200 disabled:opacity-50 disabled:cursor-not-allowed transition-all flex items-center justify-center gap-2"
            >
              {isAnalyzing ? (
                <>
                  <Loader2 className="animate-spin" size={18} />
                  Analyzing Terms...
                </>
              ) : (
                <>
                  <Scale size={18} />
                  Amplify Perspective
                </>
              )}
            </button>
          </div>
          
          <p className="mt-8 text-[11px] text-zinc-500 max-w-md text-center leading-relaxed">
            Lexicon Assist is an assistive tool for adults. It does not provide legal advice. 
            Always consult a qualified attorney before signing significant legal documents.
          </p>
        </motion.div>
      ) : (
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-6 flex-grow">
          {/* Column 1: Source Document View */}
          <motion.div 
            initial={{ opacity: 0, x: -20 }}
            animate={{ opacity: 1, x: 0 }}
            className="flex flex-col h-full"
          >
            <div className="glass-card flex-grow overflow-hidden flex flex-col">
              <div className="flex items-center gap-2 text-[11px] uppercase tracking-widest font-bold text-blue-400 mb-4">
                <div className="w-2 h-2 rounded-full bg-current" />
                Source: {file?.name || "Pasted Text"}
              </div>
              <div className="flex-grow overflow-y-auto pr-2 custom-scrollbar">
                <div className="font-serif text-[13px] leading-relaxed text-text-secondary opacity-60">
                  {textInput}
                </div>
              </div>
              <div className="mt-4 pt-4 border-t border-white/5">
                <button 
                  onClick={() => {setResult(null); setTextInput(''); setFile(null);}}
                  className="text-[10px] uppercase font-bold tracking-widest text-text-secondary hover:text-white transition-colors"
                >
                  Analyze New Document
                </button>
              </div>
            </div>
          </motion.div>

          {/* Column 2: Plain Language Summary */}
          <motion.div 
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ delay: 0.1 }}
            className="flex flex-col h-full"
          >
            <div className="glass-card flex-grow flex flex-col">
              <div className="flex items-center gap-2 text-[11px] uppercase tracking-widest font-bold text-risk-low mb-4">
                <div className="w-2 h-2 rounded-full bg-current" />
                Plain-Language Augmentation
              </div>
              <div className="flex-grow overflow-y-auto pr-2 custom-scrollbar">
                <div className="prose prose-invert prose-sm max-w-none">
                  <Markdown>{result.summary}</Markdown>
                </div>
              </div>
            </div>
          </motion.div>

          {/* Column 3: Risk Surface Map */}
          <motion.div 
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            transition={{ delay: 0.2 }}
            className="flex flex-col h-full"
          >
            <div className="glass-card h-full flex flex-col">
              <div className="flex items-center gap-2 text-[11px] uppercase tracking-widest font-bold text-risk-high mb-4">
                <div className="w-2 h-2 rounded-full bg-current" />
                Risk Surface Map
              </div>
              
              <div className="space-y-4 overflow-y-auto pr-2 custom-scrollbar">
                {result.risks.map((risk, idx) => (
                  <div 
                    key={idx}
                    className={`p-3 rounded-xl bg-white/[0.02] border-l-4 flex items-start justify-between gap-3 ${
                      risk.type === 'high' ? 'border-risk-high' : 
                      risk.type === 'mid' ? 'border-risk-mid' : 'border-risk-low'
                    }`}
                  >
                    <div className="space-y-1">
                      <div className="text-sm font-bold text-white">{risk.label}</div>
                      <div className="text-[11px] text-text-secondary font-medium uppercase tracking-tight">
                        {risk.clause}
                      </div>
                      <p className="text-[12px] text-text-secondary leading-tight mt-1">
                        {risk.desc}
                      </p>
                    </div>
                    <div className={`text-lg font-black shrink-0 ${
                      risk.type === 'high' ? 'text-risk-high' : 
                      risk.type === 'mid' ? 'text-risk-mid' : 'text-risk-low'
                    }`}>
                      {risk.score.toFixed(1)}
                    </div>
                  </div>
                ))}
              </div>

              <div className="mt-auto pt-6">
                <div className="p-4 rounded-xl bg-risk-high/5 border border-risk-high/20">
                  <div className="flex items-center gap-2 text-risk-high mb-1 font-bold text-xs uppercase tracking-tighter">
                    <ShieldAlert size={14} />
                    Critical Insight
                  </div>
                  <p className="text-[11px] text-text-secondary leading-normal">
                    The {result.documentType} contains {result.risks.filter(r => r.type === 'high').length} high-impact risk areas where your rights are significantly restricted compared to market standards.
                  </p>
                </div>
              </div>
            </div>
          </motion.div>
        </div>
      )}

      {/* Footer Tools Info */}
      <footer className="mt-10 flex flex-wrap gap-10 border-t border-glass-border pt-6 pb-2">
        <ToolGroup label="Intelligence Engine" value="Gemini 3.1 Flash / Legal-Tuned" />
        <ToolGroup label="Semantic Mapping" value="Assistive Perception Matrix" />
        <ToolGroup label="Data Standards" value="TOSDR / OpenLegal / Lexic" />
        <ToolGroup label="Target Audience" value="Adult Civil Rights Augmentation" />
      </footer>
    </div>
  );
}

function ToolGroup({ label, value }: { label: string, value: string }) {
  return (
    <div className="flex flex-col">
      <span className="text-[9px] uppercase tracking-widest text-text-secondary font-bold mb-1 opacity-70">
        {label}
      </span>
      <span className="text-[11px] text-text-primary font-medium">
        {value}
      </span>
    </div>
  );
}
